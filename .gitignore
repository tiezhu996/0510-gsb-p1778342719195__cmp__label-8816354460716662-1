# Root ignore (monorepo)
# Frontend and backend each have their own .gitignore, but keep a root one for safety.

## OS / Editor
.DS_Store
Thumbs.db
.idea/
.vscode/

## Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

## Frontend
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.*

## Backend (Python)
backend/venv/
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/.env
backend/.env.*
backend/.pytest_cache/
backend/.mypy_cache/

## Local databases
backend/database/*.db
backend/database/*.sqlite
backend/database/*.sqlite3
doc/

